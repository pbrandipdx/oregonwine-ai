# Vite (browser) — anon key only; service role must never ship to the client.
# Local Supabase (supabase start):
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=
VITE_SUPABASE_FUNCTIONS_URL=http://127.0.0.1:54321/functions/v1
# Hosted project — copy URL + anon key from Supabase → Settings → API (or match .github/workflows/ci.yml for the shared demo project).
# VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# VITE_SUPABASE_ANON_KEY=
# VITE_SUPABASE_FUNCTIONS_URL=https://YOUR_PROJECT_REF.supabase.co/functions/v1

# scripts/embed.ts and local tooling (never expose to client)
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=

# Edge Function secrets (set via `supabase secrets set` in prod)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Optional overrides
# LLM_CHAT_MODEL=claude-3-5-haiku-20241022
# EMBEDDING_MODEL=text-embedding-3-small
# MAX_CHUNKS_PER_QUERY=5
# MAX_OUTPUT_TOKENS=600
